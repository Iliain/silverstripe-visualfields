{
    "name": "iliain/silverstripe-visualfields",
    "type": "silverstripe-vendormodule",
    "description": "Provides a number of CMS fields that display images",
    "license": "BSD-3-Clause",
    "keywords": [
        "silverstripe",
        "modular",
        "cms",
        "fields"
    ],
    "homepage": "http://github.com/Iliain/silverstripe-visualfields",
    "require": {
        "php": "^8",
        "silverstripe/framework": "^5 || ^6"
    },
    "autoload": {
        "psr-4": {
            "Iliain\\VisualFields\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
